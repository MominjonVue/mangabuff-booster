{
  "manifest_version": 3,
  "name": "MangaBuff Шахта",
  "version": "1.7.1",
  "description": "Помощник для mangabuff.ru — шахта (фарм/обмен), скины профиля, аватары, авто-комментарии в клуб, блокировка трекеров (GA, Яндекс.Метрика и др.).",
  "permissions": ["storage", "tabs", "scripting", "unlimitedStorage", "alarms", "declarativeNetRequest"],
  "host_permissions": ["https://mangabuff.ru/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MangaBuff Шахта",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mangabuff.ru/users/*"],
      "js": ["content/skin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mangabuff.ru/*"],
      "js": ["content/avatar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mangabuff.ru/*"],
      "js": ["content/hide-ads.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "trackers",
        "enabled": true,
        "path": "rules/trackers.json"
      }
    ]
  }
}
